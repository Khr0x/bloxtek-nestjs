# ===========================================
# BLOXTEK BACKEND - VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo a .env.local para desarrollo local
# o .env para producción

# -----------------
# APLICACIÓN
# -----------------
NODE_ENV=development
PORT=3000

# -----------------
# BASE DE DATOS
# -----------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=postgres

# -----------------
# AUTENTICACIÓN
# -----------------
JWT_SECRET=your_jwt_secret_key_minimum_32_characters

# -----------------
# SEGURIDAD
# -----------------
PASSWORD_SALT_ROUNDS=10

# -----------------
# SEEDING (DATOS INICIALES)
# -----------------
ADMIN_EMAIL=admin@bloxtek.com
ADMIN_PASSWORD=Admin1234*!

MANAGER_EMAIL=manager@bloxtek.com
MANAGER_PASSWORD=Manager1234*!

USER_EMAIL=user@bloxtek.com
USER_PASSWORD=User1234*!

# -----------------
# URLS
# -----------------
FRONTEND_URL=http://localhost:3001
