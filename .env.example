# ===========================================
# DOCKER COMPOSE - VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo a .env para Docker Compose

# -----------------
# APLICACIÓN
# -----------------
NODE_ENV=development

# -----------------
# BASE DE DATOS
# -----------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=bloxtek_db

# -----------------
# BACKEND
# -----------------
BACKEND_PORT=3000

# -----------------
# JWT
# -----------------
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_EXPIRATION=15m

# -----------------
# SEGURIDAD
# -----------------
PASSWORD_SALT_ROUNDS=10

# -----------------
# SEEDING (DATOS INICIALES)
# -----------------
ADMIN_EMAIL=admin@bloxtek.com
ADMIN_PASSWORD=Admin1234*!

MANAGER_EMAIL=manager@bloxtek.com
MANAGER_PASSWORD=Manager1234*!

USER_EMAIL=user@bloxtek.com
USER_PASSWORD=User1234*!

# -----------------
# URLS
# -----------------
FRONTEND_URL=http://localhost:3001
